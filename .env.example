# ──────────────────────────────────────────────────────────
# TaskFlow Pro — Environment Variables
# Copy this file to backend/.env and fill in real values.
# NEVER commit the real .env file to version control.
# ──────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB
# Local:      mongodb://127.0.0.1:27017/taskflow-pro
# Atlas:      mongodb+srv://<user>:<password>@cluster0.mongodb.net/taskflow-pro
MONGO_URI=mongodb://127.0.0.1:27017/taskflow-pro

# JWT Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# CORS
CLIENT_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Frontend (Vite picks up VITE_ prefixed vars — set in frontend/.env)
VITE_API_BASE_URL=http://localhost:5000/api
